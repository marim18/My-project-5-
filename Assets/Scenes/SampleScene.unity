  dialogue:
    lines:
    - speakerName: Narrator
      text: ' This is it...


'
    - speakerName: Narrator
      text: 'The final piece must be here.



'
    - speakerName: Hero
      text: ' I can feel a dark presence...'
    - speakerName: Hero
      text: Show yourself!
    - speakerName: Boss
      text: "So... you\u2019ve come this far.\n"
    - speakerName: Boss
      text: The sword belongs to me now.
    - speakerName: Hero
      text: Try and take it, if you dare.
