  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b2a02f28e26a145ff9bc608186e07bf6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueObject
  dialogue:
    lines:
    - speakerName: Hero
      text: " Where... am I?\n "
    - speakerName: Hero
      text: 'This land feels... broken.

'
    - speakerName: Narrator
      text: "You have awakened at last!\n "
    - speakerName: Narrator
      text: "The sacred sword has been shattered into four pieces.\n "
    - speakerName: Narrator
      text: "Without it, the world will fall into darkness.\n \n "
    - speakerName: Narrator
      text: "You must find the fragments.\n\n "
    - speakerName: Narrator
      text: " Only then can you defeat the one who destroyed it... \n "
