  dialogue:
    lines:
    - speakerName: Narrator
      text: 'You found a fragment of the sword!


'
    - speakerName: Hero
      text: "It\u2019s glowing... I can feel its power.\n\n"
    - speakerName: Narrator
      text: ' Three pieces remain.


'
    - speakerName: Narrator
      text: 'Another piece restored!



'
    - speakerName: Narrator
      text: The sword is slowly returning...
